# ===========================================
# mPAPA — Environment Variables
# ===========================================
# Uses OpenRouter as LLM provider
# ===========================================

# ---- OpenRouter API Key (REQUIRED) ----
OPENROUTER_API_KEY=your-openrouter-key-here

# ---- Model Selection ----
# Best cheap models for patent drafting (June 2026):
#
# RECOMMENDED (best value):
#   google/gemini-2.5-flash      — $0.30/$2.50 per 1M tokens, 1M context
#   deepseek/deepseek-chat-v3    — $0.20/$0.77 per 1M tokens, 164K context
#
# BUDGET (cheapest):
#   google/gemini-2.5-flash-lite — $0.10/$0.40 per 1M tokens, 1M context
#   meta-llama/llama-4-scout     — $0.10/$0.30 per 1M tokens, 10M context
#
# QUALITY (if you want better results):
#   openai/gpt-4.1-mini          — $0.40/$1.60 per 1M tokens, 1M context
#   anthropic/claude-sonnet-4    — $3.00/$15.00 per 1M tokens, 1M context

PATENT_MODEL_DISCLOSURE=google/gemini-2.5-flash
PATENT_MODEL_SEARCH=google/gemini-2.5-flash
PATENT_MODEL_CLAIMS=google/gemini-2.5-flash
PATENT_MODEL_DESCRIPTION=google/gemini-2.5-flash
PATENT_MODEL_REVIEW=google/gemini-2.5-flash
PATENT_MODEL_CHAT=google/gemini-2.5-flash

# ---- Ports ----
MPAPA_PORT=8080

# ---- EPO/OPS (optional — free at developers.epo.org) ----
PATENT_EPO_OPS_KEY=
PATENT_EPO_OPS_SECRET=

# ---- Search Settings ----
PATENT_SEARCH_MAX_RESULTS_PER_SOURCE=10
PATENT_SEARCH_REQUEST_DELAY_SECONDS=3.0

# ---- Logging ----
PATENT_LOG_LEVEL=INFO
