# ===========================================
# mPAPA — Environment Variables
# ===========================================
# Copy to .env or set in Coolify UI
# ===========================================

# ---- LLM Backend ----
# Default: uses bundled Ollama container
# For external LM Studio/Ollama: set to your server URL
# For cloud API: set to OpenAI-compatible endpoint
PATENT_LM_STUDIO_BASE_URL=http://ollama:11434/v1
PATENT_LM_STUDIO_API_KEY=not-needed

# ---- Model Names ----
# Set to specific model names loaded in your LLM backend
# Use "default" to let the backend pick the active model
PATENT_MODEL_DISCLOSURE=default
PATENT_MODEL_SEARCH=default
PATENT_MODEL_CLAIMS=default
PATENT_MODEL_DESCRIPTION=default
PATENT_MODEL_REVIEW=default
PATENT_MODEL_CHAT=default

# ---- Embedding Model ----
PATENT_EMBEDDING_MODEL_NAME=text-embedding-nomic-embed-text-v1.5

# ---- Ports ----
MPAPA_PORT=8080
OLLAMA_PORT=11434

# ---- EPO/OPS (optional — free at developers.epo.org) ----
PATENT_EPO_OPS_KEY=
PATENT_EPO_OPS_SECRET=

# ---- Search Settings ----
PATENT_SEARCH_MAX_RESULTS_PER_SOURCE=10
PATENT_SEARCH_REQUEST_DELAY_SECONDS=3.0

# ---- Logging ----
PATENT_LOG_LEVEL=INFO
